# Deve coincidir com a Frontend API URL no Clerk (Dashboard → API Keys) e com o claim "iss" do JWT.
# Não use as chaves pk_ / sk_ aqui.
# https://clerk.com/docs/guides/sessions/manual-jwt-verification
#
# Ex.: https://seu-subdominio.clerk.accounts.dev
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# PostgreSQL (ex.: Neon). Se omitido, o backend usa SQLite local (database.db).
# Use o driver psycopg 3: postgresql+psycopg://...
# Neon exige SSL: adicione ?sslmode=require
# DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Re-scrape periódico (job em background)
# Intervalo em horas entre execuções automáticas (default: 12)
RESCRAPE_INTERVAL_HOURS=12
# Máximo de scrapes Playwright simultâneos no job global (default: 2)
RESCRAPE_MAX_CONCURRENT=2

# Em testes ou dev, defina 1 para não iniciar o APScheduler
# DISABLE_SCHEDULER=1
